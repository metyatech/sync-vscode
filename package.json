{
  "name": "sync-vscode",
  "displayName": "SFTP Auto Sync",
  "description": "VS Code で編集したファイルを自動的に SFTP サーバーへ同期・アップロード・ダウンロードする拡張機能です。",
  "version": "0.1.0",
  "publisher": "metyatech",
  "type": "module",
  "engines": {
    "vscode": "^1.46.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:ftp-sync.startSync",
    "onCommand:ftp-sync.stopSync",
    "onCommand:ftp-sync.configureSettings"
  ],
  "main": "./dist/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/metyatech/sync-vscode.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "ftp-sync.startSync",
        "title": "SFTP Sync: 同期を開始"
      },
      {
        "command": "ftp-sync.stopSync",
        "title": "SFTP Sync: 同期を停止"
      },
      {
        "command": "ftp-sync.configureSettings",
        "title": "SFTP Sync: 設定の変更"
      }
    ],
    "configuration": {
      "title": "SFTP Sync",
      "properties": {
        "ftpSync.host": {
          "type": "string",
          "default": "",
          "description": "SFTP サーバーのホスト名または IP アドレス"
        },
        "ftpSync.port": {
          "type": "number",
          "default": 22,
          "description": "SFTP サーバーのポート番号"
        },
        "ftpSync.user": {
          "type": "string",
          "default": "",
          "description": "SFTP ユーザー名"
        },
        "ftpSync.password": {
          "type": "string",
          "default": "",
          "description": "SFTP パスワード"
        },
        "ftpSync.remotePath": {
          "type": "string",
          "default": "/",
          "description": "リモートサーバー上のルートパス"
        },
        "ftpSync.maxUploadSize": {
          "type": "number",
          "default": 20971520,
          "description": "SFTP で同期する際の最大ファイルサイズ (バイト単位、デフォルト 20MB)"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint .",
    "test": "node ./out/test/runTest.js",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "package": "npm run build && npx vsce package",
    "verify": "npm run build && npm run lint && npm test",
    "prettier": "prettier --write ."
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.35",
    "@types/ssh2": "^1.15.5",
    "@types/vscode": "^1.46.0",
    "@typescript-eslint/eslint-plugin": "^5.1.0",
    "@typescript-eslint/parser": "^5.1.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.1.0",
    "glob": "^11.1.0",
    "mocha": "^11.7.5",
    "prettier": "^3.5.2",
    "ts-loader": "^9.5.2",
    "typescript": "^4.4.4",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "ssh2": "^1.16.0"
  }
}
